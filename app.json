{
  "expo": {
    "name": "FitFlight",
    "slug": "fitflight",
    "scheme": "fitflight",
    "version": "1.0.0",
    "icon": "./assets/images/TotalFlight_Icon_Resized.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/TotalFlight_Icon_Resized.png"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/TotalFlight_Icon_Resized.png",
        "backgroundColor": "#001F5C"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "baseUrl": "/FitFlight",
      "typedRoutes": true
    }
  }
}
