{
  "expo": {
    "name": "FitFlight",
    "slug": "fitflight",
    "scheme": "fitflight",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "favicon": "./assets/images/TotalFlight_Icon_Resized.png"
    }
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": ["expo-router"],
    "experiments": {
      "baseUrl": "/FitFlight",
      "typedRoutes": true
    }
  }
}
